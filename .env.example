# ---- App ----
NODE_ENV=development
PORT=3000
# Comma-free single origin used by the frontend; allowlist lives in src/config/origin.ts
FRONTEND_URL=http://localhost:3000
# Set true to allow any CORS origin (dev/until allowlist is complete)
CORS_PERMISSIVE=

# ---- Database (PostgreSQL) ----
# dbmate strips ?schema= and sets sslmode for you (see scripts/dbmate-runner.js)
DATABASE_URL="postgresql://postgres:password@localhost:5433/rival?schema=public"
# Set true only when supplying the RDS CA via NODE_EXTRA_CA_CERTS
DATABASE_SSL_REJECT_UNAUTHORIZED=

# ---- Redis (cache, pub/sub, BullMQ) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS_ENABLED=

# ---- Auth (JWT) ----
ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-string
# Email that is auto-granted the app-level ADMIN role on signup
DEFAULT_ADMIN_EMAIL=

# ---- Email (Resend) ----
# If unset, the email worker logs instead of sending (local dev still works)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
