# ---- App ----
NODE_ENV=development            # development | staging | production
PORT=4000
API_URL=http://localhost:4000
# Single origin used by the frontend; the CORS allowlist lives in src/config/origin.ts
FRONTEND_URL=http://localhost:3000
# Set true to allow any CORS origin (dev / until the allowlist is complete)
CORS_PERMISSIVE=
# Proxy trust for correct client IPs behind nginx/LB: true | a hop count | comma-separated IPs
TRUST_PROXY=
# Optional: directory for rotating log files (empty = stdout only)
LOG_DIR=

# ---- Database (PostgreSQL) ----
# Local: the dbmate runner strips ?schema= and sets sslmode for you (scripts/dbmate-runner.js).
# In Docker the entrypoint uses raw dbmate, so use a CLEAN url there — no ?schema=, and add
# ?sslmode=disable if your Postgres has no TLS. The host is the Postgres container name on the
# shared network in production (not localhost).
DATABASE_URL="postgresql://postgres:password@localhost:5433/rival?schema=public"
# Set true only when supplying the RDS CA via NODE_EXTRA_CA_CERTS
DATABASE_SSL_REJECT_UNAUTHORIZED=

# ---- Redis (cache, pub/sub, BullMQ) ----
# In production this is the Redis container name on the shared network (not localhost).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TLS_ENABLED=

# ---- Auth (JWT) ----
ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-string
# Email that is auto-granted the app-level ADMIN role on signup
DEFAULT_ADMIN_EMAIL=

# ---- Email (Resend) ----
# In development emails are logged to the console (never sent). In production set both:
# RESEND_API_KEY and EMAIL_FROM must use a domain verified in your Resend account.
RESEND_API_KEY=
EMAIL_FROM='Rival Tasks <noreply-rival@example.com>'
